<span class="pulse-indicator @(_healthy ? "pulse-green" : "static-red")" title="@(_healthy ? "Healthy" : "Unhealthy")"></span>

<style>
    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7); }
        70% { box-shadow: 0 0 0 6px rgba(76, 175, 80, 0); }
        100% { box-shadow: 0 0 0 0 rgba(76, 175, 80, 0); }
    }
    .pulse-indicator {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 6px;
        vertical-align: middle;
    }
    .pulse-green {
        background: #4CAF50;
        animation: pulse 2s infinite;
    }
    .static-red {
        background: #F44336;
    }
</style>

@code {
    [Parameter]
    public bool _healthy { get; set; } = true;
}
