@page "/"
@rendermode InteractiveServer
@using NeuroRoute.Dashboard.Models
@inject NeuroRoute.Dashboard.Services.NeuroRouteApiClient Api
@implements IDisposable

<PageTitle>NeuroRoute Dashboard</PageTitle>

<StatusBanner Health="@_health" />

<MudGrid Spacing="4">
    <MudItem xs="12" md="6">
        <ComponentCard Title="NPU Backend" Component="@_npu" />
    </MudItem>
    <MudItem xs="12" md="6">
        <ComponentCard Title="GPU Backend" Component="@_gpu" />
    </MudItem>
</MudGrid>

<MudGrid Spacing="4" Class="mt-2">
    <MudItem xs="12" md="6">
        <RoutingRatioChart Metrics="@_metrics" />
    </MudItem>
    <MudItem xs="12" md="6">
        <StreamingRatioChart Metrics="@_metrics" />
    </MudItem>
</MudGrid>

<MudGrid Spacing="4" Class="mt-2">
    <MudItem xs="12" md="6">
        <LatencyChart Metrics="@_metrics" />
    </MudItem>
    <MudItem xs="12" md="6">
        <CaseDistributionChart Metrics="@_metrics" />
    </MudItem>
</MudGrid>

<MudGrid Spacing="4" Class="mt-2">
    <MudItem xs="12">
        <TaskTypeTable Metrics="@_metrics" />
    </MudItem>
</MudGrid>

@code {
    private HealthStatus? _health;
    private MetricsSnapshot? _metrics;
    private ComponentHealth? _npu;
    private ComponentHealth? _gpu;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = PollAsync(_cts.Token);
    }

    private async Task Refresh()
    {
        _health = await Api.GetHealthAsync();
        _metrics = await Api.GetMetricsAsync();
        _npu = _health?.Components?.GetValueOrDefault("npu");
        _gpu = _health?.Components?.GetValueOrDefault("gpu");
    }

    private async Task PollAsync(CancellationToken ct)
    {
        while (await _timer!.WaitForNextTickAsync(ct))
        {
            await Refresh();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _timer?.Dispose();
    }
}
