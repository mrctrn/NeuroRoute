<MudCard Class="h-100">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle2">Routing Ratio</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (Metrics is null || Metrics.TotalRequests == 0)
        {
            <MudText Typo="Typo.body2" Class="text-muted text-center py-4">Awaiting data...</MudText>
        }
        else
        {
            <MudChart T="double" ChartType="ChartType.Donut" InputValues="@_values" InputLabels="@_labels" InputColors="@_colors" Width="100%" Height="200px" />
            <div class="d-flex justify-content-center gap-4 mt-2">
                <MudText Typo="Typo.caption" Class="text-success">NPU: @Metrics.NpuHandled</MudText>
                <MudText Typo="Typo.caption" Class="text-warning">GPU: @Metrics.GpuEscalated</MudText>
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public MetricsSnapshot? Metrics { get; set; }

    private double[] _values
    {
        get
        {
            if (Metrics is null) return [];
            return [Metrics.NpuHandled, Metrics.GpuEscalated];
        }
    }

    private string[] _labels => ["NPU", "GPU"];

    private string[] _colors => ["#4CAF50", "#FF9800"];
}
