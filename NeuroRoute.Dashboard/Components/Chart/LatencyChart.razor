<MudCard Class="h-100">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle2">Latency (ms)</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (Metrics is null || (Metrics.DurationMs.Min == 0 && Metrics.DurationMs.Max == 0))
        {
            <MudText Typo="Typo.body2" Class="text-muted text-center py-4">Awaiting data...</MudText>
        }
        else
        {
            <MudChart T="double" ChartType="ChartType.Bar" InputValues="@_values" InputLabels="@_labels" InputColors="@_colors" Width="100%" Height="200px" />
            <div class="d-flex justify-content-center gap-4 mt-2">
                <MudText Typo="Typo.caption" Class="text-muted">Min: @Metrics.DurationMs.Min.ToString("F0")ms</MudText>
                <MudText Typo="Typo.caption" Class="text-muted">Max: @Metrics.DurationMs.Max.ToString("F0")ms</MudText>
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public MetricsSnapshot? Metrics { get; set; }

    private double[] _values
    {
        get
        {
            if (Metrics is null) return [];
            return [Metrics.DurationMs.Min, Metrics.DurationMs.Max];
        }
    }

    private string[] _labels => ["Min", "Max"];

    private string[] _colors => ["#3F51B5", "#F44336"];
}
