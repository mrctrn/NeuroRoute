<MudCard Class="h-100">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle2">Streaming Ratio</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (Metrics is null || Metrics.TotalRequests == 0)
        {
            <MudText Typo="Typo.body2" Class="text-muted text-center py-4">Awaiting data...</MudText>
        }
        else
        {
            <MudChart T="double" ChartType="ChartType.Donut" InputValues="@_values" InputLabels="@_labels" InputColors="@_colors" Width="100%" Height="200px" />
            <div class="d-flex justify-content-center gap-4 mt-2">
                <MudText Typo="Typo.caption" Class="text-info">Stream: @Metrics.StreamingRequests</MudText>
                <MudText Typo="Typo.caption" Class="text-muted">Non-stream: @(Metrics.TotalRequests - Metrics.StreamingRequests)</MudText>
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public MetricsSnapshot? Metrics { get; set; }

    private double[] _values
    {
        get
        {
            if (Metrics is null) return [];
            var nonStream = Metrics.TotalRequests - Metrics.StreamingRequests;
            return [Metrics.StreamingRequests, nonStream < 0 ? 0 : nonStream];
        }
    }

    private string[] _labels => ["Streaming", "Non-Streaming"];

    private string[] _colors => ["#2196F3", "#9E9E9E"];
}
